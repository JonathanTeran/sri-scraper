# Dominio publico o IP del VPS.
# Ejemplos:
# API_DOMAIN=sri.midominio.com
# API_DOMAIN=203.0.113.10
API_DOMAIN=sri-process.amephia.com

# Seguridad
POSTGRES_PASSWORD=cambiar_password_largo_y_unico
SECRET_KEY=cambiar_por_clave_aleatoria_de_64_chars_minimo_32

# API / workers
API_WORKERS=2
CELERY_WORKER_CONCURRENCY=3
CELERY_LOGLEVEL=info

# CAPTCHA
CAPTCHA_PROVIDER=capsolver
TWOCAPTCHA_API_KEY=
CAPSOLVER_API_KEY=
CAPTCHA_ASSISTED_MODE=off
CAPTCHA_ASSISTED_TIMEOUT_SEC=180
ENABLE_VNC=0
ENABLE_NOVNC=0
WORKER_VNC_PORT=5900
WORKER_NOVNC_PORT=6901
VNC_PASSWORD=
RECAPTCHA_SITEKEY_FALLBACK=

# Browser
BROWSER_PREFER_NODRIVER=false
BROWSER_PERSISTENT_CONTEXT=true
BROWSER_EXECUTABLE_PATH=
BROWSER_CHANNEL=
BROWSER_PROXY_SERVER=
BROWSER_PROXY_USERNAME=
BROWSER_PROXY_PASSWORD=
BROWSER_PROXY_BYPASS=
BROWSER_TIMEOUT_MS=30000
DOWNLOAD_TIMEOUT_MS=45000

# Anti-deteccion
DELAY_MIN_MS=800
DELAY_MAX_MS=2500
DELAY_BETWEEN_PAGES_MS=2000

# Retries
MAX_RETRIES=5
RETRY_WAIT_MIN_SEC=4
RETRY_WAIT_MAX_SEC=300
CIRCUIT_BREAKER_THRESHOLD=5
CIRCUIT_BREAKER_TIMEOUT_MIN=30

# Concurrencia / DB pool
MAX_CONCURRENT_TENANTS=3
BROWSER_POOL_LIMIT=3
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# Storage dentro del contenedor
XML_STORAGE_PATH=/app/xmls
SCREENSHOT_PATH=/app/screenshots
SCREENSHOT_ON_ERROR=true
BROWSER_PROFILE_PATH=/app/chrome_profile

# Scheduler (hora Ecuador UTC-5)
SCHEDULE_HOUR=6
SCHEDULE_MINUTE=30

# Notificaciones opcionales
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
ALERT_EMAIL=

# Observabilidad opcional
SENTRY_DSN=
