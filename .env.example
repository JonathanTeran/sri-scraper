# ── Base de datos ──────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://sri:cambiar_password@localhost:5432/sri_scraper
POSTGRES_PASSWORD=cambiar_password

# ── Redis ──────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER=redis://localhost:6379/0
CELERY_BACKEND=redis://localhost:6379/1

# ── Seguridad ──────────────────────────────────────────────────────────────
# Generar con: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=cambiar_por_clave_aleatoria_de_64_chars_minimo_32

# ── CAPTCHA ────────────────────────────────────────────────────────────────
CAPTCHA_PROVIDER=capsolver
TWOCAPTCHA_API_KEY=tu_api_key_de_2captcha
CAPSOLVER_API_KEY=
CAPTCHA_ASSISTED_MODE=off
CAPTCHA_ASSISTED_TIMEOUT_SEC=180

# ── Playwright ─────────────────────────────────────────────────────────────
PLAYWRIGHT_HEADLESS=true
BROWSER_PREFER_NODRIVER=true
BROWSER_PERSISTENT_CONTEXT=true
BROWSER_EXECUTABLE_PATH=
BROWSER_CHANNEL=
BROWSER_PROFILE_PATH=./chrome_profile
BROWSER_PROXY_SERVER=
BROWSER_PROXY_USERNAME=
BROWSER_PROXY_PASSWORD=
BROWSER_PROXY_BYPASS=
BROWSER_TIMEOUT_MS=30000
DOWNLOAD_TIMEOUT_MS=45000
RECAPTCHA_SITEKEY_FALLBACK=

# ── Anti-detección ─────────────────────────────────────────────────────────
DELAY_MIN_MS=800
DELAY_MAX_MS=2500
DELAY_BETWEEN_PAGES_MS=2000

# ── Reintentos ─────────────────────────────────────────────────────────────
MAX_RETRIES=5
RETRY_WAIT_MIN_SEC=4
RETRY_WAIT_MAX_SEC=300
CIRCUIT_BREAKER_THRESHOLD=5
CIRCUIT_BREAKER_TIMEOUT_MIN=30

# ── Concurrencia ───────────────────────────────────────────────────────────
MAX_CONCURRENT_TENANTS=3
BROWSER_POOL_LIMIT=3
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# ── Storage ────────────────────────────────────────────────────────────────
XML_STORAGE_PATH=./xmls
SCREENSHOT_PATH=./screenshots
SCREENSHOT_ON_ERROR=true

# ── Scheduler (hora Ecuador UTC-5) ─────────────────────────────────────────
SCHEDULE_HOUR=6
SCHEDULE_MINUTE=30

# ── Notificaciones (opcional) ──────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
ALERT_EMAIL=

# ── Monitoreo (opcional) ───────────────────────────────────────────────────
SENTRY_DSN=
